body{
    font-family: Arial, sans-serif;
    background:#f2f2f2;
    margin:0;
    text-align:center;
}

header{
    background:#0b8f3c;
    color:white;
    padding:20px;
}

img{
    margin-top:20px;
    border-radius:10px;
}

section{
    background:white;
    width:80%;
    margin:20px auto;
    padding:20px;
    border-radius:10px;
    box-shadow:0 0 10px rgba(0,0,0,0.2);
}

footer{
    background:#222;
    color:white;
    padding:15px;
}